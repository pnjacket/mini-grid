{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "jsx": "react-jsx",
    "types": ["react"],
    "baseUrl": ".",
    "paths": {
      "@mini-grid/core": ["../../packages/core/dist/index.d.ts"],
      "@mini-grid/react": ["../../packages/react/dist/index.d.ts"],
      "@mini-grid/vue": ["../../packages/vue/dist/index.d.ts"],
      "@mini-grid/svelte": ["../../packages/svelte/dist/index.d.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
