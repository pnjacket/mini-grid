{
  "name": "@mini-grid/react",
  "version": "1.0.0",
  "description": "React adapter for @mini-grid/core.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
