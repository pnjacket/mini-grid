{
  "name": "@mini-grid/svelte",
  "version": "1.0.0",
  "description": "Svelte adapter for @mini-grid/core.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "MiniGrid.svelte"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./MiniGrid.svelte": "./MiniGrid.svelte",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mini-grid/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  }
}
