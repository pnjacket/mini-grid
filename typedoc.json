{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["packages/core/src/index.ts"],
  "tsconfig": "packages/core/tsconfig.json",
  "out": "docs/api",
  "name": "@mini-grid/core API reference",
  "readme": "none",
  "excludeInternal": true,
  "excludePrivate": true,
  "includeVersion": false,
  "githubPages": false,
  "hideGenerator": true,
  "sort": ["source-order"],
  "categorizeByGroup": true,
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": false
  }
}
